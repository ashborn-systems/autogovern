# Model provider configuration (OpenAI-compatible endpoint).
# Copy to .env and fill in real values. The key is read at runtime from the
# named environment variable and never written to disk.
MODEL_PROVIDER_API_BASE=https://openrouter.ai/api/v1
MODEL_PROVIDER_MODEL=
MODEL_PROVIDER_API_KEY_ENV=OPENROUTER_API_KEY
MODEL_PROVIDER_TEMPERATURE=0
