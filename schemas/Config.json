{
  "$defs": {
    "ModelProviderConfig": {
      "description": "Provider settings for generation and verification LLM passes.",
      "properties": {
        "api_base": {
          "title": "Api Base",
          "type": "string"
        },
        "api_key_env": {
          "title": "Api Key Env",
          "type": "string"
        },
        "model": {
          "title": "Model",
          "type": "string"
        },
        "temperature": {
          "default": 0.0,
          "title": "Temperature",
          "type": "number"
        }
      },
      "required": [
        "api_base",
        "model",
        "api_key_env"
      ],
      "title": "ModelProviderConfig",
      "type": "object"
    },
    "Thresholds": {
      "description": "Materiality score bands. Defaults: >=80 material, <=20 immaterial.",
      "properties": {
        "immaterial": {
          "default": 20,
          "title": "Immaterial",
          "type": "integer"
        },
        "material": {
          "default": 80,
          "title": "Material",
          "type": "integer"
        }
      },
      "title": "Thresholds",
      "type": "object"
    }
  },
  "description": "The ``.autogovern/config.yaml`` document.",
  "properties": {
    "documents": {
      "additionalProperties": {
        "type": "boolean"
      },
      "title": "Documents",
      "type": "object"
    },
    "model_provider": {
      "$ref": "#/$defs/ModelProviderConfig"
    },
    "thresholds": {
      "$ref": "#/$defs/Thresholds"
    },
    "watched_paths": {
      "items": {
        "type": "string"
      },
      "title": "Watched Paths",
      "type": "array"
    }
  },
  "required": [
    "model_provider"
  ],
  "title": "Config",
  "type": "object"
}
