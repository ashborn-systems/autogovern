{
  "$defs": {
    "AttentionItem": {
      "description": "An item requiring human attention, opened or closed in a run.",
      "properties": {
        "action": {
          "title": "Action",
          "type": "string"
        },
        "detail": {
          "default": "",
          "title": "Detail",
          "type": "string"
        },
        "item_id": {
          "title": "Item Id",
          "type": "string"
        }
      },
      "required": [
        "item_id",
        "action"
      ],
      "title": "AttentionItem",
      "type": "object"
    },
    "MaterialityCriterion": {
      "description": "One scored criterion within a materiality assessment.",
      "properties": {
        "criterion": {
          "title": "Criterion",
          "type": "string"
        },
        "reasoning": {
          "default": "",
          "title": "Reasoning",
          "type": "string"
        },
        "score": {
          "title": "Score",
          "type": "integer"
        }
      },
      "required": [
        "criterion",
        "score"
      ],
      "title": "MaterialityCriterion",
      "type": "object"
    },
    "MaterialityResult": {
      "description": "The outcome of the material change detection pass.",
      "properties": {
        "band": {
          "title": "Band",
          "type": "string"
        },
        "criteria": {
          "items": {
            "$ref": "#/$defs/MaterialityCriterion"
          },
          "title": "Criteria",
          "type": "array"
        },
        "score": {
          "title": "Score",
          "type": "integer"
        }
      },
      "required": [
        "score",
        "band"
      ],
      "title": "MaterialityResult",
      "type": "object"
    },
    "SectionRegeneration": {
      "description": "A section that was regenerated and the hash change that triggered it.",
      "properties": {
        "changed_input": {
          "title": "Changed Input",
          "type": "string"
        },
        "section": {
          "title": "Section",
          "type": "string"
        }
      },
      "required": [
        "section",
        "changed_input"
      ],
      "title": "SectionRegeneration",
      "type": "object"
    },
    "TokenCounts": {
      "description": "Token usage reported by the provider for a run.",
      "properties": {
        "completion": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Completion"
        },
        "prompt": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prompt"
        },
        "total": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total"
        }
      },
      "title": "TokenCounts",
      "type": "object"
    },
    "VerifierResult": {
      "description": "The verifier's verdict on one regenerated section.",
      "properties": {
        "findings": {
          "items": {
            "additionalProperties": true,
            "type": "object"
          },
          "title": "Findings",
          "type": "array"
        },
        "section": {
          "title": "Section",
          "type": "string"
        },
        "supported_claims": {
          "default": 0,
          "title": "Supported Claims",
          "type": "integer"
        },
        "unsupported_claims": {
          "default": 0,
          "title": "Unsupported Claims",
          "type": "integer"
        }
      },
      "required": [
        "section"
      ],
      "title": "VerifierResult",
      "type": "object"
    }
  },
  "description": "The audit trail written for every scan, generate, check, and diff.",
  "properties": {
    "attention_items": {
      "items": {
        "$ref": "#/$defs/AttentionItem"
      },
      "title": "Attention Items",
      "type": "array"
    },
    "command": {
      "title": "Command",
      "type": "string"
    },
    "config_snapshot": {
      "additionalProperties": true,
      "title": "Config Snapshot",
      "type": "object"
    },
    "input_hashes": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Input Hashes",
      "type": "object"
    },
    "materiality": {
      "anyOf": [
        {
          "$ref": "#/$defs/MaterialityResult"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "model_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Model Id"
    },
    "prompt_template_versions": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Prompt Template Versions",
      "type": "object"
    },
    "sections_regenerated": {
      "items": {
        "$ref": "#/$defs/SectionRegeneration"
      },
      "title": "Sections Regenerated",
      "type": "array"
    },
    "token_counts": {
      "anyOf": [
        {
          "$ref": "#/$defs/TokenCounts"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "tool_version": {
      "title": "Tool Version",
      "type": "string"
    },
    "verifier_results": {
      "items": {
        "$ref": "#/$defs/VerifierResult"
      },
      "title": "Verifier Results",
      "type": "array"
    }
  },
  "required": [
    "command",
    "tool_version"
  ],
  "title": "RunManifest",
  "type": "object"
}
