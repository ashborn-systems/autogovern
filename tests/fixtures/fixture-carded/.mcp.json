{
  "mcpServers": {
    "ticketing": {
      "command": "python",
      "args": ["-m", "ticketing_mcp"],
      "tools": [
        {
          "name": "fetch_ticket",
          "description": "Fetch a support ticket by ID.",
          "inputSchema": {
            "type": "object",
            "properties": {
              "ticket_id": { "type": "string" }
            },
            "required": ["ticket_id"]
          }
        },
        {
          "name": "assign_ticket",
          "description": "Assign a ticket to a team and set its priority.",
          "inputSchema": {
            "type": "object",
            "properties": {
              "ticket_id": { "type": "string" },
              "team": { "type": "string" },
              "priority": { "type": "string", "enum": ["P1", "P2", "P3", "P4"] }
            },
            "required": ["ticket_id", "team", "priority"]
          }
        }
      ]
    }
  }
}
